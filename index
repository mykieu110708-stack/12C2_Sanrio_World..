<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>12C2 Sanrio Adventure</title>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&display=swap" rel="stylesheet">
    <style>
        :root { --pink: #ff85a2; --bg: #fff5f7; }
        body { margin: 0; font-family: 'Quicksand', sans-serif; background: var(--bg); overflow-x: hidden; }
        .nav-tabs { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); display: flex; background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); padding: 8px; border-radius: 40px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); z-index: 2000; }
        .tab-btn { padding: 12px 20px; border: none; background: none; border-radius: 30px; font-weight: bold; cursor: pointer; color: #888; }
        .tab-btn.active { background: var(--pink); color: white; }
        .page-section { display: none; min-height: 100vh; padding-bottom: 100px; }
        .page-section.active { display: block; }
        /* Game */
        #game-container { position: relative; height: 100vh; background: #fff; overflow: hidden; }
        #player { position: absolute; bottom: 100px; width: 33.33%; display: flex; justify-content: center; font-size: 50px; transition: left 0.15s; }
        .item { position: absolute; width: 33.33%; display: flex; justify-content: center; font-size: 35px; }
        /* List */
        .member-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 15px; padding: 20px; }
        .card { background: white; padding: 15px; border-radius: 15px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    </style>
</head>
<body>

    <div class="nav-tabs">
        <button class="tab-btn active" onclick="show('game')">🎮 Game</button>
        <button class="tab-btn" onclick="show('members')">👥 12C2</button>
    </div>

    <section id="game" class="page-section active">
        <div id="game-container">
            <div style="position:absolute; top:20px; left:20px; z-index:100; font-weight:bold" id="score">🟡: 0</div>
            <div id="player" style="left: 33.33%;">🎀</div>
        </div>
    </section>

    <section id="members" class="page-section">
        <h2 style="text-align:center; color:var(--pink); margin-top:30px">Thành Viên 12C2</h2>
        <div class="member-grid" id="grid"></div>
    </section>

    <script>
        const members = [
            {n:"Lưu Hồng An", g:"Nữ"}, {n:"Lê Thị Quế An", g:"Nữ"}, {n:"Trịnh Thị Mỹ Anh", g:"Nữ"},
            {n:"Phạm Quốc Bảo", g:"Nam"}, {n:"Nguyễn Như Bảo", g:"Nam"}, {n:"Trần Quang Cảnh", g:"Nam"},
            {n:"Phạm Đức Chí Công", g:"Nam"}, {n:"Nguyễn Công Danh", g:"Nam"}, {n:"Phùng Tấn Đạt", g:"Nam"},
            {n:"Hoàng Vũ Thùy Dung", g:"Nữ"}, {n:"Đỗ Duy Dũng", g:"Nam"}, {n:"Lý Nam Hải", g:"Nam"},
            {n:"Nguyễn Thị Ngọc Hân", g:"Nữ"}, {n:"Ngô Tri Huy Hoàng", g:"Nam"}, {n:"Nguyễn Đỗ Phi Hùng", g:"Nam"},
            {n:"Trần Chấn Huy", g:"Nam"}, {n:"Trần Gia Huy", g:"Nam"}, {n:"Đặng Trần Mạnh Khang", g:"Nam"},
            {n:"Nguyễn Huỳnh Bá Khang", g:"Nam"}, {n:"Nguyễn Bá Khánh", g:"Nam"}, {n:"Võ Tuấn Khoa", g:"Nam"},
            {n:"Lý Anh Khoa", g:"Nam"}, {n:"Nguyễn Văn Duy Khoa", g:"Nam"}, {n:"Võ Phạm Đăng Khoa", g:"Nam"},
            {n:"Lê Minh Khôi", g:"Nam"}, {n:"Nguyễn Châu Khuê", g:"Nữ"}, {n:"Lê Thị Thảo Linh", g:"Nữ"},
            {n:"Trương Ngọc Linh", g:"Nữ"}, {n:"Lê Hoàng Long", g:"Nam"}, {n:"Khưu Tú Minh", g:"Nữ"},
            {n:"Nguyễn Nhật Minh", g:"Nam"}, {n:"Kiều My My", g:"Nữ"}, {n:"Trương Ngọc Thảo Ngân", g:"Nữ"},
            {n:"Thái Hà Mẫn Nghi", g:"Nữ"}, {n:"Trần Trọng Nghĩa", g:"Nam"}, {n:"Trần Hoàn Bảo Ngọc", g:"Nữ"},
            {n:"Phạm Đình Khôi Nguyên", g:"Nam"}, {n:"Trương Nguyễn Phúc", g:"Nam"}, {n:"Thạch Bảo Tài", g:"Nam"},
            {n:"Nguyễn Phước Thành", g:"Nam"}, {n:"Nguyễn Ngọc Thanh Trà", g:"Nữ"}, {n:"Phan Thùy Trang", g:"Nữ"},
            {n:"Nguyễn Thị Thanh Trúc", g:"Nữ"}, {n:"Nguyễn Đặng Khắc Trường", g:"Nam"}, {n:"Đàm Kim Tuyền", g:"Nữ"},
            {n:"Nguyễn Mỹ Phương Uyên", g:"Nữ"}, {n:"Hồ Quốc Việt", g:"Nam"}, {n:"Âu Dương Vịnh", g:"Nam"}
        ];

        function show(id) {
            document.querySelectorAll('.page-section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            event.target.classList.add('active');
        }

        const grid = document.getElementById('grid');
        grid.innerHTML = members.map(m => `<div class="card"><div>${m.g=='Nữ'?'👩‍🎓':'👨‍🎓'}</div><b>${m.n}</b></div>`).join('');

        let lane = 1; let score = 0;
        window.addEventListener('touchstart', e => {
            if (e.touches[0].clientX < window.innerWidth/2) { if(lane>0) lane--; }
            else { if(lane<2) lane++; }
            document.getElementById('player').style.left = (lane * 33.33) + "%";
        });

        function spawn() {
            if (document.getElementById('game').classList.contains('active')) {
                const item = document.createElement('div');
                const isCoin = Math.random() > 0.3;
                const l = Math.floor(Math.random()*3);
                item.className = 'item';
                item.innerText = isCoin ? '🟡' : '🧱';
                item.style.left = (l*33.33) + "%";
                item.style.top = "-50px";
                document.getElementById('game-container').appendChild(item);
                let t = -50;
                let anim = setInterval(() => {
                    t += 5; item.style.top = t + "px";
                    if (t > window.innerHeight - 150 && t < window.innerHeight - 50 && l === lane) {
                        if(isCoin) { score += 10; document.getElementById('score').innerText = "🟡: " + score; item.remove(); clearInterval(anim); }
                        else { alert("Game Over! Điểm: " + score); score = 0; document.getElementById('score').innerText = "🟡: 0"; item.remove(); clearInterval(anim); }
                    }
                    if (t > window.innerHeight) { item.remove(); clearInterval(anim); }
                }, 20);
            }
        }
        setInterval(spawn, 1200);
    </script>
</body>
</html>
